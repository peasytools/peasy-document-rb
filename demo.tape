# peasy-document-rb — Markdown, HTML, CSV conversion (Ruby)
# Theme: Nord
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "nord"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-document-rb — Markdown, HTML, CSV conversion for Ruby"
Enter
Type "# peasyformats.com"
Enter
Sleep 500ms

# Run the demo
Type "ruby -I lib examples/demo.rb"
Enter
Sleep 5s
